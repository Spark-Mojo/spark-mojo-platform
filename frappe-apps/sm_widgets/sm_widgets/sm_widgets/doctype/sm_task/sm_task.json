{
  "name": "SM Task",
  "module": "SM Widgets",
  "doctype": "DocType",
  "document_type": "Document",
  "engine": "InnoDB",
  "is_submittable": 0,
  "track_changes": 1,
  "autoname": "TASK-.#####",
  "naming_rule": "Expression (old style)",
  "custom": 0,
  "istable": 0,
  "issingle": 0,
  "editable_grid": 1,
  "fields": [
    {
      "fieldname": "title",
      "label": "Title",
      "fieldtype": "Data",
      "reqd": 1,
      "max_length": 200,
      "in_list_view": 1,
      "in_standard_filter": 0
    },
    {
      "fieldname": "task_type",
      "label": "Task Type",
      "fieldtype": "Select",
      "reqd": 1,
      "options": "Action\nReview\nApproval\nInput\nException\nMonitoring\nSystem",
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "description",
      "label": "Description",
      "fieldtype": "Long Text",
      "reqd": 0
    },
    {
      "fieldname": "section_ownership",
      "label": "Ownership",
      "fieldtype": "Section Break"
    },
    {
      "fieldname": "assigned_user",
      "label": "Assigned User",
      "fieldtype": "Link",
      "options": "User",
      "reqd": 0,
      "in_standard_filter": 1
    },
    {
      "fieldname": "assigned_role",
      "label": "Assigned Role",
      "fieldtype": "Link",
      "options": "Role",
      "reqd": 0,
      "in_standard_filter": 1
    },
    {
      "fieldname": "assigned_team",
      "label": "Assigned Team",
      "fieldtype": "Link",
      "options": "Team",
      "reqd": 0
    },
    {
      "fieldname": "executor_type",
      "label": "Executor Type",
      "fieldtype": "Select",
      "reqd": 1,
      "options": "Human\nSystem\nHybrid",
      "in_list_view": 1
    },
    {
      "fieldname": "created_by_user",
      "label": "Created By",
      "fieldtype": "Link",
      "options": "User",
      "reqd": 1,
      "read_only": 1,
      "default": "__user"
    },
    {
      "fieldname": "section_mode",
      "label": "Task Mode",
      "fieldtype": "Section Break"
    },
    {
      "fieldname": "task_mode",
      "label": "Task Mode",
      "fieldtype": "Select",
      "reqd": 1,
      "options": "active\nwatching\nsnoozed",
      "default": "active",
      "in_list_view": 1,
      "in_standard_filter": 1,
      "description": "active = intervention required. watching = visibility only, no action needed. snoozed = deferred until snooze_until date."
    },
    {
      "fieldname": "snooze_until",
      "label": "Snooze Until",
      "fieldtype": "Datetime",
      "reqd": 0,
      "description": "Required when task_mode = snoozed. Scheduler flips mode to active when this datetime passes."
    },
    {
      "fieldname": "section_state",
      "label": "State & Lifecycle",
      "fieldtype": "Section Break"
    },
    {
      "fieldname": "canonical_state",
      "label": "Status",
      "fieldtype": "Select",
      "reqd": 1,
      "options": "New\nReady\nIn Progress\nWaiting\nBlocked\nCompleted\nCanceled\nFailed",
      "default": "New",
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "source_state",
      "label": "Source State",
      "fieldtype": "Data",
      "reqd": 0
    },
    {
      "fieldname": "status_reason",
      "label": "Status Reason",
      "fieldtype": "Small Text",
      "reqd": 0
    },
    {
      "fieldname": "priority",
      "label": "Priority",
      "fieldtype": "Select",
      "reqd": 1,
      "options": "Low\nMedium\nHigh\nUrgent",
      "default": "Medium",
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "section_dates",
      "label": "Dates",
      "fieldtype": "Section Break"
    },
    {
      "fieldname": "due_at",
      "label": "Due Date",
      "fieldtype": "Datetime",
      "reqd": 0
    },
    {
      "fieldname": "started_at",
      "label": "Started At",
      "fieldtype": "Datetime",
      "reqd": 0,
      "read_only": 1
    },
    {
      "fieldname": "completed_at",
      "label": "Completed At",
      "fieldtype": "Datetime",
      "reqd": 0,
      "read_only": 1
    },
    {
      "fieldname": "canceled_at",
      "label": "Canceled At",
      "fieldtype": "Datetime",
      "reqd": 0,
      "read_only": 1
    },
    {
      "fieldname": "section_sla",
      "label": "SLA",
      "fieldtype": "Section Break"
    },
    {
      "fieldname": "sla_hours",
      "label": "SLA Hours",
      "fieldtype": "Float",
      "reqd": 0
    },
    {
      "fieldname": "sla_breached",
      "label": "SLA Breached",
      "fieldtype": "Check",
      "default": "0",
      "read_only": 1
    },
    {
      "fieldname": "sla_breached_at",
      "label": "SLA Breached At",
      "fieldtype": "Datetime",
      "read_only": 1
    },
    {
      "fieldname": "section_source",
      "label": "Source & Context",
      "fieldtype": "Section Break"
    },
    {
      "fieldname": "source_system",
      "label": "Source System",
      "fieldtype": "Select",
      "options": "Frappe\nn8n\nEHR\nStripe\nManual\nAI"
    },
    {
      "fieldname": "source_object_id",
      "label": "Source Object ID",
      "fieldtype": "Data"
    },
    {
      "fieldname": "related_crm_record",
      "label": "Related CRM Contact",
      "fieldtype": "Link",
      "options": "CRM Contact"
    },
    {
      "fieldname": "workflow_id",
      "label": "Workflow",
      "fieldtype": "Link",
      "options": "SM Workflow Config"
    },
    {
      "fieldname": "workflow_stage",
      "label": "Workflow Stage",
      "fieldtype": "Data"
    },
    {
      "fieldname": "parent_task",
      "label": "Parent Task",
      "fieldtype": "Link",
      "options": "SM Task"
    },
    {
      "fieldname": "section_execution",
      "label": "Execution",
      "fieldtype": "Section Break"
    },
    {
      "fieldname": "completion_criteria",
      "label": "Completion Criteria",
      "fieldtype": "Small Text"
    },
    {
      "fieldname": "waiting_trigger",
      "label": "Waiting Trigger",
      "fieldtype": "Small Text"
    },
    {
      "fieldname": "is_recurring",
      "label": "Recurring Instance",
      "fieldtype": "Check"
    },
    {
      "fieldname": "recurrence_template_id",
      "label": "Recurrence Template ID",
      "fieldtype": "Data"
    },
    {
      "fieldname": "section_activity",
      "label": "Activity",
      "fieldtype": "Section Break"
    },
    {
      "fieldname": "watchers",
      "label": "Watchers",
      "fieldtype": "Table",
      "options": "SM Task Watcher"
    },
    {
      "fieldname": "tags",
      "label": "Tags",
      "fieldtype": "Table",
      "options": "SM Task Tag"
    },
    {
      "fieldname": "comments",
      "label": "Comments",
      "fieldtype": "Table",
      "options": "SM Task Comment"
    },
    {
      "fieldname": "section_audit",
      "label": "Audit Trail",
      "fieldtype": "Section Break"
    },
    {
      "fieldname": "state_history",
      "label": "State History",
      "fieldtype": "Table",
      "options": "SM Task State History"
    },
    {
      "fieldname": "assignment_history",
      "label": "Assignment History",
      "fieldtype": "Table",
      "options": "SM Task Assignment History"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "submit": 0,
      "cancel": 0,
      "amend": 0
    }
  ],
  "sort_field": "modified",
  "sort_order": "DESC",
  "title_field": "title",
  "search_fields": "title, canonical_state, assigned_user"
}
