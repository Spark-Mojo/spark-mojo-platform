{
  "port": 8103,
  "baseUrl": "http://medplum:8103",
  "issuer": "http://medplum:8103",
  "jwksUrl": "http://medplum:8103/.well-known/jwks.json",
  "authorizeUrl": "http://medplum:8103/oauth2/authorize",
  "tokenUrl": "http://medplum:8103/oauth2/token",
  "userInfoUrl": "http://medplum:8103/oauth2/userinfo",
  "appBaseUrl": "http://medplum:8103",
  "binaryStorage": "file:./binary/",
  "maxJsonSize": "16mb",
  "supportEmail": "dev@sparkmojo.com",
  "registerEnabled": false,
  "googleClientId": "",
  "recaptchaSiteKey": "",
  "logLevel": "info",
  "auditEventLogEnabled": true,
  "auditEventInDatabase": true,
  "heartbeatMilliseconds": 10000,
  "heartbeatEnabled": true,
  "database": {
    "host": "medplum-postgres",
    "port": 5432,
    "dbname": "medplum",
    "username": "medplum",
    "password": "MEDPLUM_DB_PASSWORD_FROM_ENV_POC"
  },
  "redis": {
    "host": "medplum-redis",
    "port": 6379,
    "password": "MEDPLUM_REDIS_PASSWORD_FROM_ENV_POC"
  }
}
